{
  "name": "kuadrant-console-plugin",
  "version": "0.3.7-dev",
  "description": "Kuadrant OpenShift Console plugin",
  "private": true,
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/kuadrant/kuadrant-console-plugin.git"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "yarn clean && NODE_ENV=production yarn webpack",
    "build-dev": "yarn clean && yarn webpack",
    "start": "yarn webpack serve --progress",
    "start-console": "./start-console.sh",
    "oinc": "./start-local.sh",
    "oinc:teardown": "./scripts/teardown.sh",
    "i18n": "./i18n-scripts/build-i18n.sh && node ./i18n-scripts/set-english-defaults.js",
    "lint": "yarn eslint src --fix && stylelint 'src/**/*.css' --allow-empty-input --fix",
    "test:e2e": "npx playwright test --config=e2e/playwright.config.ts",
    "test:e2e:setup": "./e2e/setup.sh",
    "test:e2e:teardown": "./e2e/teardown.sh",
    "webpack": "node -r ts-node/register ./node_modules/.bin/webpack",
    "downstream-replacements": "node downstream.js && yarn i18n && yarn lint",
    "upstream-replacements": "node downstream.js --upstream && yarn i18n && yarn lint"
  },
  "resolutions": {
    "http-proxy-middleware": "2.0.7",
    "immutable": "3.8.3",
    "lodash": "4.18.0",
    "node-forge": "^1.3.2",
    "qs": "6.14.1"
  },
  "devDependencies": {
    "@openshift-console/dynamic-plugin-sdk": "^1.6.0",
    "@openshift-console/dynamic-plugin-sdk-webpack": "^1.2.0",
    "@patternfly/react-core": "^6.2.2",
    "@patternfly/react-icons": "^6.2.2",
    "@playwright/test": "^1.50.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^18.0.0",
    "@types/react": "^17.0.37",
    "@types/react-helmet": "^6.1.4",
    "@types/react-router-dom": "^5.3.2",
    "@typescript-eslint/eslint-plugin": "^5.14.0",
    "@typescript-eslint/parser": "^5.14.0",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^6.7.1",
    "eslint": "^8.10.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-prettier": "^4.0.0",
    "eslint-plugin-react": "^7.29.1",
    "mocha": "^11.7.5",
    "mocha-junit-reporter": "^2.2.0",
    "mochawesome": "^7.1.3",
    "mochawesome-merge": "^4.3.0",
    "prettier": "^2.7.1",
    "prettier-stylelint": "^0.4.2",
    "react": "^17.0.1",
    "react-dom": "^17.0.1",
    "react-helmet": "^6.1.0",
    "react-i18next": "^11.7.3",
    "react-router": "5.3.x",
    "react-router-dom": "5.3.x",
    "style-loader": "^3.3.1",
    "stylelint": "^15.3.0",
    "stylelint-config-standard": "^31.0.0",
    "ts-loader": "^9.3.1",
    "ts-node": "^10.8.1",
    "typescript": "^5.0.0",
    "webpack": "5.75.0",
    "webpack-cli": "^4.9.2",
    "webpack-dev-server": "^4.7.4"
  },
  "consolePlugin": {
    "name": "kuadrant-console-plugin",
    "version": "0.3.7-dev",
    "displayName": "Kuadrant OpenShift Console Plugin",
    "description": "Kuadrant OpenShift Console Plugin",
    "latestSupportedOpenshiftVersion": "4.19",
    "i18n": {
      "loadType": "Preload"
    },
    "exposedModules": {
      "KuadrantOverviewPage": "./components/KuadrantOverviewPage",
      "PolicyTopologyPage": "./components/PolicyTopologyPage",
      "KuadrantPoliciesPage": "./components/KuadrantPoliciesPage",
      "KuadrantDNSPolicyCreatePage": "./components/KuadrantDNSPolicyCreatePage",
      "KuadrantAuthPolicyCreatePage": "./components/KuadrantAuthPolicyCreatePage",
      "KuadrantRateLimitPolicyCreatePage": "./components/KuadrantRateLimitPolicyCreatePage",
      "KuadrantTokenRateLimitPolicyCreatePage": "./components/KuadrantTokenRateLimitPolicyCreatePage",
      "KuadrantOIDCPolicyCreatePage": "./components/KuadrantOIDCPolicyCreatePage",
      "KuadrantPlanPolicyCreatePage": "./components/KuadrantPlanPolicyCreatePage",
      "KuadrantTLSCreatePage": "./components/KuadrantTLSCreatePage",
      "HTTPRoutePoliciesPage": "./components/HTTPRoutePoliciesPage",
      "GatewayPoliciesPage": "./components/GatewayPoliciesPage",
      "PolicyTargetRefPage": "./components/PolicyTargetRefPage",
      "APIProductCreatePage": "./components/apiproduct/APIProductCreatePage",
      "APIProductsListPage": "./components/apiproduct/APIProductsListPage",
      "APIProductPoliciesTab": "./components/apiproduct/APIProductPoliciesTab",
      "APIProductDefinitionTab": "./components/apiproduct/APIProductDefinitionTab",
      "useDNSPolicyActions": "./components/dnspolicy/useDNSPolicyActions",
      "useTLSPolicyActions": "./components/tlspolicy/useTLSPolicyActions"
    },
    "dependencies": {
      "@console/pluginAPI": "*"
    }
  },
  "dependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/preset-react": "^7.24.7",
    "@patternfly/react-code-editor": "^5.4.0",
    "@patternfly/react-table": "^6.2.2",
    "@patternfly/react-topology": "^6.2.0",
    "babel-loader": "^8.2.0",
    "graphlib": "^2.1.8",
    "graphlib-dot": "^0.6.4",
    "i18next": "^25.8.0",
    "i18next-parser": "^9.0.1",
    "js-yaml": "^4.1.0",
    "pluralize": "^8.0.0",
    "swagger-ui-react": "5.10.5"
  },
  "packageManager": "yarn@4.12.0"
}
